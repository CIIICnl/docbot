{
  "name": "CIIIC",
  "description": "Professional theme with GT America typography, lime yellow accents and teal highlights",
  "version": "1.0.0",
  "author": "CIIIC",
  "private": true,
  "fonts": {
    "heading": {
      "family": "GT America Extended",
      "ttf": "fonts/heading/GT-America-Extended-Medium.ttf",
      "woff2": "fonts/heading/GT-America-Extended-Medium.woff2"
    },
    "body": {
      "family": "GT America",
      "regular": {
        "woff2": "fonts/body/GT-America-Standard-Regular.woff2"
      },
      "bold": {
        "ttf": "fonts/body/GT-America-Standard-Bold.ttf",
        "woff2": "fonts/body/GT-America-Standard-Bold.woff2"
      },
      "italic": {
        "ttf": "fonts/body/GT-America-Standard-Regular-Italic.ttf",
        "woff2": "fonts/body/GT-America-Standard-Regular-Italic.woff2"
      },
      "boldItalic": {
        "woff2": "fonts/body/GT-America-Standard-Bold-Italic.woff2"
      }
    },
    "caption": {
      "family": "JetBrains Mono",
      "ttf": "fonts/captions/JetBrainsMono-Regular.ttf",
      "woff2": "fonts/captions/JetBrainsMono-Regular.woff2"
    }
  },
  "colors": {
    "text": "#141414",
    "heading": "#141414",
    "accent": "#dbff00",
    "primary": "#38766d",
    "link": "#38766d",
    "link-hover": "#2c5f57",
    "code-bg": "#f6f8fa",
    "code-text": "#d6336c",
    "border": "#ddd",
    "muted": "#777777",
    "toc-bg": "#f5f5f5",
    "callout-bg": "#e0e5e2",
    "callout-border": "#dbff00"
  },
  "pageSettings": {
    "format": "A4",
    "margins": {
      "top": "2cm",
      "right": "2cm",
      "bottom": "2cm",
      "left": "2cm"
    }
  }
}
