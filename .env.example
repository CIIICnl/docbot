# Server
PORT=3001
NODE_ENV=development

# ============================================
# Authentication (required for production)
# ============================================

# Secret key for signing session cookies (generate with: openssl rand -hex 32)
AUTH_SECRET=

# User credentials - use ONE of these formats:
# JSON format (for local dev):
# AUTH_USERS_JSON={"jaap@ciiic.nl":{"password":"your-password","role":"admin","name":"Jaap"}}
#
# Base64 format (recommended for production - encode the JSON above):
# AUTH_USERS_B64=

# Optional: Default admin email (defaults to jaap@ciiic.nl)
# AUTH_ADMIN_EMAIL=jaap@ciiic.nl

# Enable dev bypass button on login page (for local development only!)
# AUTH_DEV_BYPASS=1

# Force secure cookies (set to 1 in production behind HTTPS)
# SECURE_COOKIES=1

# Cookie domain for cross-subdomain SSO (e.g., .ciiic.nl)
# This allows sharing login between slides.ciiic.nl, docs.ciiic.nl, etc.
# COOKIE_DOMAIN=.ciiic.nl

# ============================================
# Notion Integration (optional)
# ============================================
# Get your API key from https://www.notion.so/my-integrations
NOTION_API_KEY=

# ============================================
# LLM Integration (optional - for Word document enhancement)
# ============================================
# Claude API - Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mistral API - Get your key from https://console.mistral.ai/
MISTRAL_API_KEY=

# ============================================
# Database (PostgreSQL)
# ============================================
# Storage mode: 'postgres' or 'file' (default: file)
STORAGE_MODE=postgres

# Database connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=docbot
DATABASE_USER=docbot
DATABASE_PASSWORD=docbot

# SSL configuration (auto-enabled for non-localhost)
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Connection pool
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# Default organization ID for single-tenant deployments
# DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# ============================================
# Media Storage (S3-compatible)
# ============================================
# Storage mode: 'auto', 'scaleway', or 'local' (default: auto)
# auto = use Scaleway if configured, otherwise local
MEDIA_STORAGE_MODE=auto

# Scaleway Object Storage (S3-compatible)
# SCW_ACCESS_KEY=
# SCW_SECRET_KEY=
# SCW_BUCKET=ciiic-media
# SCW_REGION=nl-ams
# SCW_KEY_PREFIX=docbot/

# Local storage directory (relative to project root)
# UPLOADS_DIR=server/uploads
